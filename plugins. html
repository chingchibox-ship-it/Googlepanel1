<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AAFTL Plugins</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#0d1117;
color:white;
}

header{
background:#111827;
padding:20px;
text-align:center;
font-size:30px;
font-weight:bold;
color:#00ff88;
}

.container{
max-width:1200px;
margin:auto;
padding:30px;
}

.search{
width:100%;
padding:15px;
border:none;
border-radius:10px;
font-size:18px;
margin-bottom:30px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
}

.plugin{
background:#161b22;
border-radius:12px;
padding:20px;
transition:.3s;
}

.plugin:hover{
transform:translateY(-5px);
}

.plugin h2{
color:#00ff88;
margin-bottom:10px;
}

.tag{
display:inline-block;
background:#00ff88;
color:black;
padding:5px 10px;
border-radius:6px;
margin-bottom:10px;
font-size:13px;
}

button{
margin-top:15px;
padding:10px 20px;
border:none;
border-radius:8px;
background:#00ff88;
font-weight:bold;
cursor:pointer;
}
</style>
</head>

<body>

<header>AAFTL Plugins</header>

<div class="container">

<input
class="search"
id="search"
placeholder="Search plugins..."
onkeyup="searchPlugin()">

<div class="grid" id="plugins">

<div class="plugin">
<span class="tag">Core</span>
<h2>AAFTL Core</h2>
<p>Main dependency plugin.</p>
<button>View</button>
</div>

<div class="plugin">
<span class="tag">Survival</span>
<h2>AAFTL Lifesteal</h2>
<p>Heart stealing plugin.</p>
<button>View</button>
</div>

<div class="plugin">
<span class="tag">Teleport</span>
<h2>AAFTL RTP</h2>
<p>Random teleport plugin.</p>
<button>View</button>
</div>

<div class="plugin">
<span class="tag">Crates</span>
<h2>AAFTL Crates</h2>
<p>Create animated crates.</p>
<button>View</button>
</div>

<div class="plugin">
<span class="tag">Economy</span>
<h2>AAFTL Shop</h2>
<p>Modern GUI shop plugin.</p>
<button>View</button>
</div>

</div>

</div>

<script>

function searchPlugin(){

let input=document.getElementById("search").value.toLowerCase();

let cards=document.getElementsByClassName("plugin");

for(let i=0;i<cards.length;i++){

let title=cards[i].innerText.toLowerCase();

cards[i].style.display=
title.includes(input)?"block":"none";

}

}

</script>

</body>
</html>